# Normalise line endings to LF; protects WSL + Windows mixed workflows.
* text=auto eol=lf

*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.svg    text
*.csv    text eol=lf
*.parquet binary
*.sh     text eol=lf
*.py     text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
